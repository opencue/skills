{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git push origin main)",
      "Bash(git push origin main:main)",
      "Bash(git push)"
    ]
  },
  "autoMode": {
    "allow": [
      "$defaults",
      "On the recodeee/skills repository, pushing directly to `main` is the established workflow (recent history shows commits land on main directly, no PR review). Allow `git push origin main` and equivalent pushes to the default branch without flagging that PR review is being bypassed."
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/deadpool/Documents/recodeee/skills/scripts/sync-mcps.sh && /home/deadpool/Documents/recodeee/skills/scripts/import-globals.sh && /home/deadpool/Documents/recodeee/skills/scripts/auto-push.sh",
            "timeout": 30,
            "statusMessage": "skills auto-sync"
          }
        ]
      }
    ]
  }
}
